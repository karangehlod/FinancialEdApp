# ===== Application Settings =====
# Application name and version
APP_NAME="Financial Education API"
APP_VERSION="1.0.0"

# Debug mode (set to false in production)
DEBUG=false

# Environment (development, staging, production)
ENVIRONMENT=production

# API prefix for all routes
API_V1_PREFIX="/api/v1"

# ===== Auth Database (Users & Authentication) =====
# PostgreSQL database for user management and authentication
AUTH_DB_USER=finedu_admin
AUTH_DB_PASSWORD=change_me_in_production
AUTH_DB_HOST=localhost
AUTH_DB_PORT=55432
AUTH_DB_NAME=auth_db

# ===== Data Database (Financial Data) =====
# PostgreSQL database for user financial data, budgets, loans, etc.
DATA_DB_USER=finedu_admin
DATA_DB_PASSWORD=change_me_in_production
DATA_DB_HOST=localhost
DATA_DB_PORT=55433
DATA_DB_NAME=financial_ed_db

# ===== JWT & Security Settings =====
# Change this to a strong random string in production
JWT_SECRET_KEY="change_me_in_production_use_strong_random_string"

# JWT algorithm (HS256 recommended)
JWT_ALGORITHM="HS256"

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS Configuration =====
# Allowed origins (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173"

# ===== Redis Configuration =====
# Redis connection URL for caching and sessions
REDIS_URL="redis://:finedu_redis_password@localhost:56379/0"

# ===== Email Configuration (Optional) =====
# SMTP server for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@financialedu.com"
SMTP_FROM_NAME="Financial Education App"
EMAIL_ENABLED=false

# ===== Notification Settings =====
# Days to retain notifications in database
NOTIFICATION_RETENTION_DAYS=30

# Feature flags for notifications
SEND_BUDGET_ALERTS=true
SEND_LOAN_REMINDERS=true
SEND_GOAL_NOTIFICATIONS=true

# Budget alert threshold (percentage of budget spent)
BUDGET_ALERT_THRESHOLD=80.0

# ===== AI / Chat (Azure OpenAI / OpenAI) =====
# If using Azure OpenAI, set the AZURE_* values. Otherwise set OPENAI_API_KEY for direct OpenAI access.
AZURE_OPENAI_API_KEY="KEY"
AZURE_OPENAI_ENDPOINT="endpointlink"
# Deployment name / alias
AZURE_OPENAI_DEPLOYMENT="gpt-4.1-nano"
# Compatibility alias some tooling expects
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4.1-nano"
AZURE_OPENAI_MODEL="gpt-4.1-nano"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
# Optional per-provider temperature (mapped to CHAT_TEMPERATURE in code)
AZURE_OPENAI_TEMPERATURE=0.7

# Direct OpenAI API key (used when not using Azure)
OPENAI_API_KEY=""

# Chat tuning (app uses these variable names)
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1500
CHAT_MAX_HISTORY=20

# Additional helper vars (not used by app by default but provided)
TEMP_VAR=0.1
MAX_TOKENS=1500

# Feature flag to enable chat/AI features
FEATURE_CHAT_ENABLED=true

