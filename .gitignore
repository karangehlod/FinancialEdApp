*.log
*.tmp
.DS_Store
node_modules/
dist/
.env
.vscode/

# Ignore build files
build/
out/
*.exe
*.dll
*.so
*.dylib

# Ignore IDE specific files
.idea/
*.iml
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# Ignore coverage reports
coverage/
*.lcov

# Ignore package manager files
.pnpm-debug.log
yarn-error.log

# Ignore Python virtual environments and cache files
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Ignore environment and coverage files
.env
.coverage
htmlcov/

# Ignore temporary files and logs
*.swp
*.swo
*.bak
*.orig
*.rej
*.tmp
*.temp
*.log
*.log.*

# Ignore specific deployment files
*.tar.gz
*.zip
*.war
*.jar
*.ear
*.apk
*.ipa
*.deb
*.rpm
*.snap

# Ignore database dumps
*.sqlite
*.db
*.db-journal

