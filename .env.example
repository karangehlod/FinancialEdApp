# =============================================================================
# FinancialEdApp — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env (with real secrets) to version control.
#
# All tunables here can be changed without rebuilding the Docker image.
# After changing a value, run:  docker compose up -d  (hot-reloads env vars)
#
# REQUIRED fields have no default and MUST be set.  The app will refuse
# to start if they are missing.
# =============================================================================

# =============================================================================
# Application
# =============================================================================
APP_NAME="FinancialEdApp"
APP_VERSION="1.0.0"
ENVIRONMENT="production"            # development | staging | production
DEBUG=false
LOG_LEVEL="INFO"                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_V1_PREFIX="/api/v1"

# =============================================================================
# CORS — comma-separated list of allowed origins
# =============================================================================
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# =============================================================================
# JWT / Security  (REQUIRED — generate with: openssl rand -hex 32)
# =============================================================================
JWT_SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet encryption key for TOTP secrets + OAuth tokens.
# Leave empty in development; in production generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=""

# =============================================================================
# Auth Database  (users, refresh_tokens, oauth_accounts)  [REQUIRED]
# =============================================================================
POSTGRES_USER="finedu_admin"
POSTGRES_PASSWORD="CHANGE_ME_strong_db_password"

AUTH_DB_HOST="postgres_auth"        # Docker service name (or 'localhost' for local dev)
AUTH_DB_PORT=5432
AUTH_DB_NAME="auth_db"
AUTH_DB_USER="finedu_admin"
AUTH_DB_PASSWORD="CHANGE_ME_strong_db_password"

# Port published on the host machine (for local psql access)
AUTH_DB_EXPOSED_PORT=55432

# =============================================================================
# Data Database  (expenses, budgets, goals, loans …)  [REQUIRED]
# =============================================================================
DATA_DB_HOST="postgres_data"        # Docker service name (or 'localhost' for local dev)
DATA_DB_PORT=5432
DATA_DB_NAME="financial_ed_db"
DATA_DB_USER="finedu_admin"
DATA_DB_PASSWORD="CHANGE_ME_strong_db_password"

# Port published on the host machine (for local psql access)
DATA_DB_EXPOSED_PORT=55433

# =============================================================================
# Database Connection Pool  (tunable without image rebuild)
# Adjust based on number of backend replicas and DB server capacity.
# Rule of thumb: pool_size × workers ≤ max_connections (PostgreSQL default 100)
# =============================================================================
DB_POOL_SIZE=20                     # Persistent connections per worker
DB_MAX_OVERFLOW=40                  # Burst connections on top of pool_size
DB_POOL_TIMEOUT=30                  # Seconds to wait for a free connection
DB_POOL_RECYCLE=1800                # Recycle connections after N seconds
DB_POOL_PRE_PING=true               # Validate before checkout (handles DB restarts)
PGBOUNCER_MODE=false                # Set true when using PgBouncer transaction mode

# =============================================================================
# Redis — cache, rate-limit store, WebSocket pub/sub  [REQUIRED]
# =============================================================================
REDIS_PASSWORD="CHANGE_ME_strong_redis_password"
REDIS_URL="redis://:CHANGE_ME_strong_redis_password@redis:6379/0"
REDIS_MAX_MEMORY="256mb"            # Max memory for Redis; eviction: allkeys-lru

# Redis connection pool
REDIS_MAX_CONNECTIONS=50            # Max pool connections
REDIS_SOCKET_CONNECT_TIMEOUT=5     # Seconds to wait for connection
REDIS_SOCKET_KEEPALIVE=true
REDIS_RETRY_ON_TIMEOUT=true

# Port published on the host machine
REDIS_EXPOSED_PORT=56379

# =============================================================================
# Cache TTLs (seconds) — all tunable per environment
# =============================================================================
CACHE_TTL_USER_PROFILE=300          # 5 min
CACHE_TTL_EXPENSES=300              # 5 min
CACHE_TTL_BUDGETS=300               # 5 min
CACHE_TTL_GOALS=300                 # 5 min
CACHE_TTL_ACCESS_TOKEN=1800         # 30 min (match JWT expiry)
CACHE_TTL_EXCHANGE_RATES=3600       # 1 hour

# =============================================================================
# Rate Limiting  (all tunable without redeploy)
# Format: RATE_LIMIT_<ENDPOINT>_LIMIT  /  RATE_LIMIT_<ENDPOINT>_WINDOW (seconds)
# =============================================================================
# Auth endpoints — tight to prevent brute-force / credential stuffing
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW=60          # 5 requests per 60 seconds

RATE_LIMIT_REGISTER_LIMIT=3
RATE_LIMIT_REGISTER_WINDOW=60       # 3 requests per 60 seconds

RATE_LIMIT_FORGOT_PASSWORD_LIMIT=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=3600   # 3 requests per hour

RATE_LIMIT_REFRESH_LIMIT=10
RATE_LIMIT_REFRESH_WINDOW=60        # 10 requests per 60 seconds

RATE_LIMIT_OAUTH_LIMIT=10
RATE_LIMIT_OAUTH_WINDOW=60

# Expensive / resource-heavy endpoints
RATE_LIMIT_EXPORTS_LIMIT=10
RATE_LIMIT_EXPORTS_WINDOW=60

RATE_LIMIT_ANALYTICS_LIMIT=30
RATE_LIMIT_ANALYTICS_WINDOW=60

# Default limits for authenticated / unauthenticated API traffic
RATE_LIMIT_DEFAULT_AUTH_LIMIT=300
RATE_LIMIT_DEFAULT_AUTH_WINDOW=60

RATE_LIMIT_DEFAULT_UNAUTH_LIMIT=60
RATE_LIMIT_DEFAULT_UNAUTH_WINDOW=60

# Account lockout after N consecutive failed logins (sliding window)
RATE_LIMIT_LOCKOUT_MAX_FAILURES=5
RATE_LIMIT_LOCKOUT_WINDOW=900       # 15-minute sliding window

# =============================================================================
# Email / SMTP  (optional — set EMAIL_ENABLED=true to activate)
# =============================================================================
EMAIL_ENABLED=false
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@financialedu.com"
SMTP_FROM_NAME="Financial Education App"

# URL used in verification/reset email links
FRONTEND_URL="http://localhost:3000"

# =============================================================================
# Notifications
# =============================================================================
NOTIFICATION_RETENTION_DAYS=30
SEND_BUDGET_ALERTS=true
SEND_LOAN_REMINDERS=true
SEND_GOAL_NOTIFICATIONS=true
BUDGET_ALERT_THRESHOLD=80.0         # % of budget at which an alert fires

# =============================================================================
# Observability / Metrics
# =============================================================================
# Optional HTTP Basic auth on the /metrics endpoint
METRICS_USERNAME=""
METRICS_PASSWORD=""
# OTLP gRPC endpoint for OpenTelemetry (leave empty to use console exporter)
OTEL_EXPORTER_ENDPOINT=""

# =============================================================================
# OAuth / Social Login  (optional — leave empty to disable)
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""                # Multi-line PEM — use \n escape or Docker secret

# =============================================================================
# Multi-Currency
# =============================================================================
OPEN_EXCHANGE_RATES_API_KEY=""      # https://openexchangerates.org
BASE_CURRENCY="USD"

# =============================================================================
# GDPR / Compliance
# =============================================================================
GDPR_ACCOUNT_RETENTION_DAYS=730    # Auto-delete inactive accounts after 2 years (0=disabled)
GDPR_DATA_EXPORT_TTL=86400          # Seconds the export download link stays valid

# =============================================================================
# Feature Flags  (all can be toggled without rebuild)
# =============================================================================
FEATURE_2FA_ENABLED=true
FEATURE_OAUTH_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_GDPR_ENABLED=true
FEATURE_ADMIN_ENABLED=true
FEATURE_CURRENCY_CONVERSION_ENABLED=true

# =============================================================================
# Docker Port Bindings  (host-side ports — change if there are conflicts)
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# Frontend Build Args  (baked into the React build at image build time)
# =============================================================================
VITE_API_URL="http://localhost:8000/api/v1"
